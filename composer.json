{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "northwestern-sysdev/chassis",
    "description": "Framework utilities for Laravel applications",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "northwestern"
    ],
    "homepage": "https://github.com/NIT-Administrative-Systems/chassis",
    "support": {
        "issues": "https://github.com/NIT-Administrative-Systems/chassis/issues",
        "source": "https://github.com/NIT-Administrative-Systems/chassis"
    },
    "require": {
        "php": "^8.3",
        "filament/support": "^4.0||^5.0",
        "laravel/framework": "^12.0||^13.0",
        "owen-it/laravel-auditing": "^14.0",
        "spatie/laravel-package-tools": "^1.16",
        "zircote/swagger-php": "^5.0||^6.0"
    },
    "require-dev": {
        "brianium/paratest": "^7.8",
        "driftingly/rector-laravel": "^2.0",
        "lab404/laravel-impersonate": "^1.7",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.1",
        "phpunit/phpunit": "^12.0",
        "rector/rector": "^2.0",
        "spatie/laravel-db-snapshots": "^2.7"
    },
    "suggest": {
        "spatie/laravel-db-snapshots": "Required for database snapshot commands",
        "sentry/sentry-laravel": "Required for SentryExceptionHandler",
        "lab404/laravel-impersonate": "Required for impersonator tracking in audit records"
    },
    "autoload": {
        "psr-4": {
            "Northwestern\\SysDev\\Chassis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Northwestern\\SysDev\\Chassis\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Northwestern\\SysDev\\Chassis\\ChassisServiceProvider"
            ]
        }
    },
    "scripts": {
        "rector": "vendor/bin/rector process --ansi",
        "rector:dry": "vendor/bin/rector process --dry-run --ansi",
        "format:php": "vendor/bin/pint --ansi",
        "analyse:php": "vendor/bin/phpstan analyse --memory-limit=2G",
        "test": "vendor/bin/pest",
        "test:update-shards": "@php -d memory_limit=-1 ./vendor/bin/pest --update-shards --colors=always",
        "all": [
            "@rector",
            "@format:php",
            "@analyse:php"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
