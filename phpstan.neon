includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - src
    level: 10
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        -
            identifier: trait.unused
            path: src/Seeding/Concerns/AuditsSeederChanges.php
        # These classes are intentionally referenced to check if the consuming app
        # still has its own inline versions during migration. They don't exist in
        # the chassis's own context — that's the point of the check.
        -
            message: '#Class App\\Console\\Commands\\#'
            path: src/ChassisServiceProvider.php
        # Scope is class-level generic in Laravel 13 but not in 12. We annotate
        # for 13; silence the "not generic" complaint for 12.
        -
            identifier: generics.notGeneric
            path: src/Models/Scopes/AutomaticallyOrderedScope.php
